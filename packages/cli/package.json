{
  "name": "@glubean/cli",
  "version": "0.2.6",
  "type": "module",
  "bin": {
    "glubean": "./bin/gb.js"
  },
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js",
      "default": "./dist/main.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@glubean/sdk": "workspace:*",
    "@glubean/runner": "workspace:*",
    "@glubean/scanner": "workspace:*",
    "@glubean/redaction": "workspace:*",
    "commander": "^13.0.0",
    "@inquirer/prompts": "^7.0.0",
    "archiver": "^7.0.0",
    "dotenv": "^16.4.0",
    "tsx": "^4.19.0",
    "yaml": "^2.7.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@glubean/graphql": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/archiver": "^6.0.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/glubean/glubean.git",
    "directory": "packages/cli"
  }
}
